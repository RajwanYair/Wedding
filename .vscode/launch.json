{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Vite: Chrome",
      "type": "chrome",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Vite: Edge",
      "type": "msedge",
      "request": "launch",
      "url": "http://localhost:5173",
      "webRoot": "${workspaceFolder}/src",
      "sourceMaps": true,
      "sourceMapPathOverrides": {
        "/@fs/*": "${workspaceFolder}/*"
      }
    },
    {
      "name": "Vitest: Debug current file",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/../MyScripts/node_modules/vitest/vitest.mjs",
      "args": ["run", "${relativeFile}", "--reporter=verbose"],
      "cwd": "${workspaceFolder}",
      "env": { "NODE_NO_WARNINGS": "1" },
      "console": "integratedTerminal",
      "sourceMaps": true
    },
    {
      "name": "Vitest: Debug all tests",
      "type": "node",
      "request": "launch",
      "program": "${workspaceFolder}/../MyScripts/node_modules/vitest/vitest.mjs",
      "args": ["run", "--reporter=verbose"],
      "cwd": "${workspaceFolder}",
      "env": { "NODE_NO_WARNINGS": "1" },
      "console": "integratedTerminal",
      "sourceMaps": true
    }
  ]
}
