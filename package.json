{
    "name": "wedding-manager",
    "version": "5.5.0",
    "description": "Wedding Management App — Hebrew RTL, RSVP, table seating, WhatsApp confirmations",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "vite",
        "build": "vite build",
        "postbuild": "node scripts/generate-precache.mjs",
        "preview": "vite preview",
        "test": "vitest run",
        "test:watch": "vitest",
        "test:coverage": "vitest run --coverage",
        "test:e2e": "playwright test",
        "lint:html": "htmlhint --config .htmlhintrc index.html",
        "lint:css": "stylelint --cache --cache-location node_modules/.cache/stylelint/ --config .stylelintrc.json --max-warnings 0 css/*.css",
        "lint:js": "eslint --cache --cache-location node_modules/.cache/eslint/ --max-warnings 0 \"src/**/*.js\" scripts vite.config.js eslint.config.mjs",
        "lint:md": "markdownlint-cli2 README.md CHANGELOG.md \".github/**/*.md\"",
        "lint": "npm run lint:html && npm run lint:css && npm run lint:js && npm run lint:md",
        "lint:fix": "npm run lint:css -- --fix && npm run lint:js -- --fix",
        "icons": "node scripts/generate-icons.mjs",
        "sri": "node scripts/sri-check.mjs",
        "precache": "node scripts/generate-precache.mjs",
        "size": "node scripts/size-report.mjs",
        "docs": "node scripts/generate-docs.mjs",
        "typecheck": "tsc --noEmit",
        "validate": "node scripts/validate-actions.mjs",
        "ci": "npm run lint && npm run typecheck && npm test"
    },
    "engines": {
        "node": ">=20.0.0"
    },
    "comment:deps": "All devDependencies are installed in the parent MyScripts/ workspace. Run `npm install` from ../MyScripts to provision. CI uses its own npm ci.",
    "devDependencies": {
        "@eslint/js": "^10.2.0",
        "@playwright/test": "^1.59.1",
        "@vitest/coverage-v8": "^4.1.4",
        "eslint": "^10.2.0",
        "htmlhint": "^1.9.2",
        "markdownlint-cli2": "^0.22.0",
        "serve": "^14.2.6",
        "stylelint": "^17.7.0",
        "stylelint-config-standard": "^40.0.0",
        "vite": "^8.0.8",
        "vitest": "^4.1.4",
        "web-push": "^3.6.7"
    }
}
